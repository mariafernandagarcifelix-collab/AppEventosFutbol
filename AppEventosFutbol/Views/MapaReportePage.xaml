<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="AppEventosFutbol.Views.MapaReportePage"
             Title="Mapa"
             BackgroundColor="{StaticResource DarkBg}">

    <Grid>
        <maps:Map x:Name="mapaReportes" MapClicked="OnMapClicked" />

        <!-- Top Overlay: Búsqueda y Favoritos -->
        <VerticalStackLayout Margin="16,48,16,0" VerticalOptions="Start" Spacing="12">
            <!-- Barra de Búsqueda -->
            <Border BackgroundColor="{StaticResource CardBg}" Stroke="{StaticResource BorderSubtle}" StrokeThickness="1" HeightRequest="50">
                <Border.StrokeShape><RoundRectangle CornerRadius="25"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="#40000000" Offset="0,4" Radius="10" Opacity="0.8"/></Border.Shadow>
                <SearchBar x:Name="searchBarUbicacion" Placeholder="Buscar una ubicación..." 
                           PlaceholderColor="{StaticResource TextMuted}" TextColor="{StaticResource TextPrimary}"
                           CancelButtonColor="{StaticResource TextSecondary}"
                           SearchButtonPressed="OnBuscarUbicacion" />
            </Border>

            <!-- Carrusel de Estadios con Eventos -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout x:Name="carouselEstadios" Spacing="8" />
            </ScrollView>
        </VerticalStackLayout>

        <!-- Banner de instrucción para ruta -->
        <Border x:Name="bannerInstruccion" IsVisible="False" BackgroundColor="{StaticResource WarningAmber}" 
                Padding="16,12" Margin="32,140,32,0" VerticalOptions="Start" StrokeThickness="0">
            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
            <Border.Shadow><Shadow Brush="#40000000" Offset="0,4" Radius="10" Opacity="0.8"/></Border.Shadow>
            <Label Text="Toca en el mapa para marcar tu punto de origen 📍" 
                   TextColor="White" FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="13"/>
        </Border>

        <!-- Tarjeta de Info de Ruta -->
        <Border x:Name="tarjetaRutaInfo" IsVisible="False" BackgroundColor="{StaticResource CardBg}" 
                Padding="16" Margin="16,140,16,0" VerticalOptions="Start" StrokeThickness="1" Stroke="{StaticResource BorderSubtle}">
            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
            <Border.Shadow><Shadow Brush="#40000000" Offset="0,4" Radius="12" Opacity="0.8"/></Border.Shadow>
            <VerticalStackLayout Spacing="8">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Label Grid.Column="0" Text="📍" VerticalOptions="Center" Margin="0,0,8,0"/>
                    <Label x:Name="lblRutaOrigen" Grid.Column="1" Text="Tu Ubicación" TextColor="{StaticResource TextPrimary}" FontAttributes="Bold" VerticalOptions="Center" />
                    <ImageButton Grid.Column="2" WidthRequest="24" HeightRequest="24" BackgroundColor="Transparent" Clicked="OnCerrarRutaClicked">
                        <ImageButton.Source>
                            <FontImageSource Glyph="✖" Color="{StaticResource TextSecondary}" Size="12"/>
                        </ImageButton.Source>
                    </ImageButton>
                </Grid>
                <BoxView HeightRequest="1" Color="{StaticResource DividerColor}" Margin="0,4"/>
                <Grid ColumnDefinitions="*, *">
                    <VerticalStackLayout Grid.Column="0">
                        <Label Text="TIEMPO EST." TextColor="{StaticResource TextGray}" FontSize="10" FontAttributes="Bold"/>
                        <Label x:Name="lblRutaTiempo" Text="-- min" TextColor="{StaticResource SuccessGreen}" FontSize="18" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1">
                        <Label Text="DISTANCIA" TextColor="{StaticResource TextGray}" FontSize="10" FontAttributes="Bold"/>
                        <Label x:Name="lblRutaDistancia" Text="-- km" TextColor="{StaticResource TextPrimary}" FontSize="18" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Grid>
            </VerticalStackLayout>
        </Border>
        <!-- Floating card at bottom — premium dark glassmorphism -->
        <Border x:Name="tarjetaEvento" 
                BackgroundColor="{StaticResource CardBg}" 
                Stroke="{StaticResource BorderSubtle}"
                StrokeThickness="1" 
                IsVisible="False" 
                VerticalOptions="End" 
                Margin="16,0,16,28" 
                Padding="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="#50000000" Offset="0,10" Radius="30" Opacity="0.95"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="0">

                <!-- Header verde con equipos -->
                <Grid MinimumHeightRequest="90"  Padding="20,16">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#006847" Offset="0.0"/>
                            <GradientStop Color="#003D2A" Offset="0.7"/>
                            <GradientStop Color="#0D1117" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Glow decorativo -->
                    <BoxView Opacity="0.04" WidthRequest="150" HeightRequest="150"
                             HorizontalOptions="End" TranslationX="30" TranslationY="-20">
                        <BoxView.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="White" Offset="0.0"/>
                                <GradientStop Color="Transparent" Offset="1.0"/>
                            </RadialGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="6">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label x:Name="lblSede" Grid.Column="0" Text="🏟️ Estadio" 
                                   TextColor="#99FFFFFF" FontSize="12" FontAttributes="Bold"/>
                            <ImageButton Grid.Column="1" WidthRequest="30" HeightRequest="30" 
                                         BackgroundColor="#22FFFFFF" CornerRadius="15" 
                                         Clicked="OnCerrarTarjetaClicked">
                                <ImageButton.Source>
                                    <FontImageSource Glyph="✖" Color="White" Size="12"/>
                                </ImageButton.Source>
                            </ImageButton>
                        </Grid>
                        <Label x:Name="lblEquipos" Text="Equipo 1 vs Equipo 2" 
                               TextColor="White" FontSize="20" FontAttributes="Bold" 
                               CharacterSpacing="-0.3" LineBreakMode="WordWrap"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Detalles -->
                <VerticalStackLayout Padding="20,16" Spacing="14">
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📅" VerticalOptions="Center" FontSize="14"/>
                        <Label x:Name="lblFecha" Text="21 de Septiembre, 20:00 hrs" 
                               TextColor="{StaticResource MexGreen}" FontSize="14" 
                               FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource DividerColor}"/>

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="BOLETOS DISPONIBLES" TextColor="{StaticResource TextGray}" 
                                   FontSize="10" CharacterSpacing="0.8" FontAttributes="Bold"/>
                            <Label x:Name="lblBoletos" Text="1,000" 
                                   TextColor="{StaticResource TextPrimary}" 
                                   FontSize="20" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="PRECIO" TextColor="{StaticResource TextGray}" 
                                   FontSize="10" CharacterSpacing="0.8" FontAttributes="Bold"/>
                            <Label x:Name="lblPrecio" Text="$1,500.00" 
                                   TextColor="{StaticResource MexGold}" 
                                   FontSize="20" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Button Text="📍 ¿Cómo llegar?" Style="{StaticResource PrimaryButton}" 
                            Margin="0,8,0,0" Clicked="OnComoLlegarClicked" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>

        <!-- Loader / Activity Indicator -->
        <Grid x:Name="gridCargando" IsVisible="False" BackgroundColor="#80000000">
            <Border BackgroundColor="{StaticResource CardBg}" Padding="24"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    Stroke="{StaticResource BorderSubtle}" StrokeThickness="1">
                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                <Border.Shadow><Shadow Brush="#50000000" Offset="0,10" Radius="30" Opacity="0.95"/></Border.Shadow>
                <VerticalStackLayout Spacing="16">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource MexGreen}" />
                    <Label Text="Calculando ruta..." TextColor="White" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
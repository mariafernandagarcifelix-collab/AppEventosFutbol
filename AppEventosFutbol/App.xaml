<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AppEventosFutbol"
             x:Class="AppEventosFutbol.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- 🎨  PALETA PREMIUM DARK — ESTADIO NOCTURNO           -->
            <!-- ══════════════════════════════════════════════════════ -->

            <!-- Fondos principales (DARK THEME — premium nocturno) -->
            <Color x:Key="DarkBg">#0D1117</Color>
            <Color x:Key="DarkBgSecondary">#161B22</Color>
            <Color x:Key="CardBg">#1C2128</Color>
            <Color x:Key="CardBgElevated">#212830</Color>
            <Color x:Key="SurfaceDim">#171D24</Color>
            <Color x:Key="InputBg">#141920</Color>

            <!-- Bordes & separadores -->
            <Color x:Key="BorderSubtle">#252D38</Color>
            <Color x:Key="BorderMedium">#30394A</Color>
            <Color x:Key="BorderFocus">#006847</Color>
            <Color x:Key="DividerColor">#1E2630</Color>

            <!-- Texto -->
            <Color x:Key="TextPrimary">#ECEFF4</Color>
            <Color x:Key="TextSecondary">#8B949E</Color>
            <Color x:Key="TextGray">#6E7681</Color>
            <Color x:Key="TextMuted">#484F58</Color>
            <Color x:Key="TextDark">#ECEFF4</Color>
            <Color x:Key="TextOnGreen">#FFFFFF</Color>

            <!-- Colores de marca México — vibrantes para dark -->
            <Color x:Key="MexGreen">#00A86B</Color>
            <Color x:Key="MexGreenLight">#2DD4A0</Color>
            <Color x:Key="MexGreenDark">#006847</Color>
            <Color x:Key="MexGreenSubtle">#0D2818</Color>
            <Color x:Key="MexRed">#FF4D5E</Color>
            <Color x:Key="MexRedLight">#FF6B7A</Color>
            <Color x:Key="MexRedDark">#CC2836</Color>
            <Color x:Key="MexRedSubtle">#2D0F14</Color>
            <Color x:Key="MexWhite">#FFFFFF</Color>
            <Color x:Key="MexGold">#FFD700</Color>
            <Color x:Key="MexGoldDark">#B8970A</Color>

            <!-- Acentos de estado -->
            <Color x:Key="SuccessGreen">#2DD4A0</Color>
            <Color x:Key="WarningAmber">#FFAB40</Color>
            <Color x:Key="DangerRed">#FF5252</Color>
            <Color x:Key="InfoBlue">#448AFF</Color>

            <!-- Sombra -->
            <Color x:Key="ShadowColor">#40000000</Color>

            <!-- Hero overlay -->
            <Color x:Key="HeroOverlayStart">#CC006847</Color>
            <Color x:Key="HeroOverlayEnd">#E6000000</Color>

            <!-- Tab bar -->
            <Color x:Key="TabBarBg">#0D1117</Color>
            <Color x:Key="TabBarActive">#00A86B</Color>
            <Color x:Key="TabBarInactive">#484F58</Color>

            <!-- Glassmorphism -->
            <Color x:Key="GlassBg">#2A1C2128</Color>
            <Color x:Key="GlassBorder">#33FFFFFF</Color>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- 🎯  ESTILOS REUTILIZABLES                            -->
            <!-- ══════════════════════════════════════════════════════ -->

            <Style x:Key="SectionLabel" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.6"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
            </Style>

            <Style x:Key="PageTitle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontSize" Value="30"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="-0.5"/>
            </Style>

            <Style x:Key="PageSubtitle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource MexGreen}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="1.0"/>
            </Style>

            <Style x:Key="HeroTagline" TargetType="Label">
                <Setter Property="TextColor" Value="#99FFFFFF"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="2.5"/>
            </Style>

            <Style x:Key="HeroTitle" TargetType="Label">
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="-0.3"/>
            </Style>

            <Style x:Key="HeroSubtitle" TargetType="Label">
                <Setter Property="TextColor" Value="#80FFFFFF"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource MexGreen}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="HeightRequest" Value="56"/>
                <Setter Property="CharacterSpacing" Value="0.8"/>
            </Style>

            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource MexRedDark}"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="HeightRequest" Value="56"/>
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent"/>
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}"/>
                <Setter Property="BorderWidth" Value="1.5"/>
                <Setter Property="BorderColor" Value="{StaticResource BorderMedium}"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="HeightRequest" Value="56"/>
                <Setter Property="FontSize" Value="15"/>
            </Style>

            <Style x:Key="GoldButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource MexGold}"/>
                <Setter Property="TextColor" Value="#1C1C1E"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="CornerRadius" Value="16"/>
                <Setter Property="HeightRequest" Value="56"/>
                <Setter Property="CharacterSpacing" Value="0.5"/>
            </Style>

            <Style x:Key="Divider" TargetType="BoxView">
                <Setter Property="HeightRequest" Value="1"/>
                <Setter Property="Color" Value="{StaticResource DividerColor}"/>
                <Setter Property="Margin" Value="0,8"/>
            </Style>

            <Style x:Key="StatValue" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontSize" Value="20"/>
                <Setter Property="FontAttributes" Value="Bold"/>
                <Setter Property="CharacterSpacing" Value="-0.3"/>
            </Style>

            <Style x:Key="StatCaption" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource TextGray}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="CharacterSpacing" Value="0.8"/>
            </Style>

            <!-- PremiumCard -->
            <Style x:Key="PremiumCard" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBg}"/>
                <Setter Property="Stroke" Value="{StaticResource BorderSubtle}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="Padding" Value="22"/>
            </Style>

            <!-- InputBorder -->
            <Style x:Key="InputBorder" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource InputBg}"/>
                <Setter Property="Stroke" Value="{StaticResource BorderSubtle}"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="HeightRequest" Value="52"/>
                <Setter Property="Padding" Value="14,0"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
